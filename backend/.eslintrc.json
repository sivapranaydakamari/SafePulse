{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "warn",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "no-undef": "error",
    "curly": ["error", "all"],
    "no-throw-literal": "error",
    "no-return-await": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/"
  ]
}
