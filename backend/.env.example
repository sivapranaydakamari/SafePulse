PORT=5000
MONGODB_URI=mongodb://localhost:27017/safepulse
JWT_SECRET=replace-with-a-long-random-secret

# TLS / HTTPS — set USE_HTTPS=true to enable Node.js direct TLS (alternative to nginx termination)
USE_HTTPS=false
TLS_KEY_PATH=./certs/server.key
TLS_CERT_PATH=./certs/server.crt
HTTPS_PORT=443

AI_SERVICE_URL=http://localhost:7000
SPRING_EMERGENCY_SERVICE_URL=http://localhost:8080

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FIREBASE_SERVICE_ACCOUNT_PATH=
EMAIL_USER=
EMAIL_PASS=
