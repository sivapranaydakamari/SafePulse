rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // live_locations: writable only by the owner; readable only by members
    // of any circle that the document owner belongs to.
    match /live_locations/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;

      // A reader is allowed if they are a member of at least one circle
      // that the tracked user (userId) is also a member of.
      // Membership is stored as sub-documents: circles/{circleId}/members/{uid}
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/circles/$(resource.data.circleId)/members/$(request.auth.uid));
    }

    // circles: readable/writable by verified members only
    match /circles/{circleId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));

      // Members sub-collection — allow member to read their own doc
      match /members/{memberId} {
        allow read: if request.auth != null && request.auth.uid == memberId;
        allow write: if request.auth != null &&
          exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
      }
    }

    // circle_locations: safety circle live location mirror
    match /circle_locations/{docId} {
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/circles/$(resource.data.circleId)/members/$(request.auth.uid));
    }

    // Default deny — no implicit access to any other collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
